---
import Layout from '../layouts/Layout.astro';
const FORMSPREE_ID = 'xzdlpvwl';
---

<Layout title="Contact" description="Contact Ulwandle Plumbing & Construction — call, WhatsApp, or send a message.">

  <section class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Reach out any way that works for you. We respond fast.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">

      <!-- Contact methods -->
      <div class="contact-methods">
        <h2>Get in Touch</h2>
        <div class="teal-rule" style="margin-left:0;"></div>

        <div class="method-card">
          <span class="method-icon">📞</span>
          <div>
            <h3>Phone</h3>
            <p>Call us directly — best for emergencies and quick queries.</p>
            <a href="tel:0731346229" class="contact-link">Ornat: 073 134 6229</a>
            <a href="tel:0735902855" class="contact-link">Vela: 073 590 2855</a>
          </div>
        </div>

        <div class="method-card">
          <span class="method-icon">💬</span>
          <div>
            <h3>WhatsApp</h3>
            <p>Send photos of the job, get quick quotes. We love WhatsApp.</p>
            <a href="https://wa.me/27731346229?text=Hi%20Ulwandle%21%20I%20need%20help%20with%20a%20job." target="_blank" rel="noopener" class="contact-link">
              Chat with Ornat →
            </a>
            <a href="https://wa.me/27735902855?text=Hi%20Ulwandle%21%20I%20need%20help%20with%20a%20job." target="_blank" rel="noopener" class="contact-link">
              Chat with Vela →
            </a>
          </div>
        </div>

        <div class="method-card">
          <span class="method-icon">✉️</span>
          <div>
            <h3>Email</h3>
            <p>For quotes, invoices, and non-urgent enquiries.</p>
            <span class="contact-link muted">Email coming soon</span>
          </div>
        </div>

        <div class="method-card">
          <span class="method-icon">🕐</span>
          <div>
            <h3>Hours</h3>
            <p>We're available for emergencies around the clock.</p>
            <span class="hours-line"><strong>Mon – Fri:</strong> 07:00 – 18:00</span>
            <span class="hours-line"><strong>Sat:</strong> 08:00 – 14:00</span>
            <span class="hours-line teal"><strong>Emergencies:</strong> 24/7</span>
          </div>
        </div>
      </div>

      <!-- Quick contact form -->
      <div class="contact-form-wrap">
        <h2>Send a Message</h2>
        <form method="POST" action={`https://formspree.io/f/${FORMSPREE_ID}`}>
          <div class="form-group">
            <label for="c-name">Name *</label>
            <input type="text" id="c-name" name="name" required placeholder="Your name" />
          </div>
          <div class="form-group">
            <label for="c-phone">Phone *</label>
            <input type="tel" id="c-phone" name="phone" required placeholder="Your number" />
          </div>
          <div class="form-group">
            <label for="c-msg">Message *</label>
            <textarea id="c-msg" name="message" required placeholder="What do you need help with?"></textarea>
          </div>
          <input type="text" name="_gotcha" style="display:none" />
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Send Message →</button>
        </form>
      </div>
    </div>
  </section>

</Layout>

<style>
.page-hero {
  background: var(--navy);
  color: var(--white);
  padding: 3.5rem 0;
  text-align: center;
}
.page-hero h1 { color: var(--white); margin-bottom: 0.5rem; }
.page-hero p { opacity: 0.75; }

.contact-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3.5rem;
  align-items: start;
}

.contact-methods h2 { margin-bottom: 0.5rem; }

.method-card {
  display: flex;
  gap: 1rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--border);
}
.method-card:last-child { border-bottom: none; }
.method-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
.method-card h3 { font-size: 1rem; margin-bottom: 0.25rem; }
.method-card p { color: var(--muted); font-size: 0.88rem; margin-bottom: 0.5rem; }

.contact-link {
  display: block;
  color: var(--teal);
  font-weight: 700;
  font-size: 0.95rem;
  margin-bottom: 0.2rem;
  text-decoration: none;
}
.contact-link:hover { color: var(--teal-dark); }
.contact-link.muted { color: var(--muted); font-weight: 400; font-style: italic; }

.hours-line { display: block; font-size: 0.9rem; margin-bottom: 0.15rem; color: var(--text); }
.hours-line.teal { color: var(--teal); }

.contact-form-wrap h2 { margin-bottom: 1.5rem; }

@media (max-width: 768px) {
  .contact-layout { grid-template-columns: 1fr; }
}
</style>

---
import Layout from '../layouts/Layout.astro';

const values = [
  { icon: '🎯', title: 'Reliable', desc: 'We show up when we say we will. No ghosting, no excuses.' },
  { icon: '🔍', title: 'Skilled', desc: 'Plumbing, electrical, construction — trained across all three trades.' },
  { icon: '💬', title: 'Honest', desc: 'Upfront pricing. We tell you what the job costs before we start.' },
  { icon: '🌊', title: 'The Ulwandle Way', desc: '"Ulwandle" means ocean in Zulu — deep expertise, steady reliability, calm in a crisis.' },
];
---

<Layout title="About Us" description="About Ulwandle Plumbing & Construction — who we are, what we stand for, and why clients trust us.">

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="badge badge-teal">Our Story</span>
      <h1>About Ulwandle</h1>
      <p>A skilled, reliable trades team — plumbing, electrical, and construction under one roof.</p>
    </div>
  </section>

  <!-- Story -->
  <section class="section">
    <div class="container story-grid">
      <div class="story-text">
        <h2>Who We Are</h2>
        <div class="teal-rule" style="margin-left:0;"></div>
        <p>
          Ulwandle Plumbing &amp; Construction was founded by Ornat and Vela — two experienced
          tradespeople with a shared belief that clients deserve professionals who are skilled,
          punctual, and honest about pricing.
        </p>
        <p>
          The name <em>Ulwandle</em> — the Zulu word for ocean — reflects that philosophy: deep
          knowledge, constant flow, and a calm steadiness that customers can rely on, especially
          in a crisis.
        </p>
        <p>
          We cover the full spectrum of residential trades: plumbing from geysers to burst pipes,
          electrical from full wiring to fault-finding, and construction from tiling to full house
          renovations. One team. All trades. One call.
        </p>

        <div class="team-contacts">
          <div class="team-card">
            <div class="team-avatar">O</div>
            <div>
              <strong>Ornat</strong>
              <a href="tel:0731346229">073 134 6229</a>
            </div>
          </div>
          <div class="team-card">
            <div class="team-avatar">V</div>
            <div>
              <strong>Vela</strong>
              <a href="tel:0735902855">073 590 2855</a>
            </div>
          </div>
        </div>
      </div>

      <div class="story-values">
        {values.map(v => (
          <div class="value-card">
            <span class="value-icon">{v.icon}</span>
            <div>
              <h3>{v.title}</h3>
              <p>{v.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="container cta-inner">
      <div>
        <h2>Ready to work with us?</h2>
        <p>Get a free, no-obligation quote on your job.</p>
      </div>
      <a href="/quote" class="btn btn-primary">Request a Quote →</a>
    </div>
  </section>

</Layout>

<style>
.page-hero {
  background: var(--navy);
  color: var(--white);
  padding: 3.5rem 0;
  text-align: center;
}
.page-hero h1 { color: var(--white); margin: 0.5rem 0; }
.page-hero p { opacity: 0.75; }

.story-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3.5rem;
  align-items: start;
}

.story-text p {
  color: var(--muted);
  margin-bottom: 1rem;
  line-height: 1.75;
}
.story-text em { color: var(--teal); font-style: normal; font-weight: 600; }

.team-contacts { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }
.team-card {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: var(--offwhite);
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  padding: 0.75rem 1rem;
  flex: 1;
  min-width: 160px;
}
.team-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--navy);
  color: var(--teal);
  font-weight: 800;
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.team-card strong { display: block; color: var(--navy); }
.team-card a { color: var(--teal); font-size: 0.9rem; font-weight: 600; }

.value-card {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem;
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 1rem;
  transition: box-shadow 0.2s;
}
.value-card:hover { box-shadow: var(--shadow); }
.value-icon { font-size: 1.6rem; flex-shrink: 0; margin-top: 2px; }
.value-card h3 { margin-bottom: 0.2rem; font-size: 1rem; }
.value-card p { color: var(--muted); font-size: 0.9rem; margin: 0; }

.cta-band { background: var(--teal); padding: 3rem 0; }
.cta-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; }
.cta-band h2 { color: var(--navy); margin-bottom: 0.25rem; }
.cta-band p { color: var(--navy); opacity: 0.75; }
.cta-band .btn-primary { background: var(--navy); border-color: var(--navy); }
.cta-band .btn-primary:hover { background: #0d2d55; border-color: #0d2d55; }

@media (max-width: 768px) {
  .story-grid { grid-template-columns: 1fr; }
  .cta-inner { text-align: center; justify-content: center; }
}
</style>
